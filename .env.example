# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Found in: Supabase Dashboard → Project Settings → Database → Connection Pooling
# Use the "Transaction" pooler URI (port 6543) — NOT the direct connection
SUPABASE_DB_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres

# ─── Groq ────────────────────────────────────────────────────────────────────
# Get at: console.groq.com → API Keys
GROQ_API_KEY=gsk_your_key_here

# ─── Gemini ──────────────────────────────────────────────────────────────────
# Get at: aistudio.google.com → Get API Key
GEMINI_API_KEY=AIza_your_key_here

# ─── App ─────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed for CORS (local dev + Vercel production URL)
CORS_ORIGINS=http://localhost:5173,https://rag-arena-three.vercel.app

# Environment: "development" or "production"
APP_ENV=development
